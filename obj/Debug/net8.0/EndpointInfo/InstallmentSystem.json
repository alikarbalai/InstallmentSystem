  "components": {
    "schemas": {
      "CancelPaymentDto": {
        "type": "object",
        "properties": {
          "cancelReason": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "ContractItemDto": {
        "type": "object",
        "properties": {
          "productId": {
            "type": "string",
            "format": "uuid"
          },
          "quantity": {
            "type": "integer",
            "format": "int32"
          },
          "price": {
            "type": "number",
            "format": "double"
          }
        },
        "additionalProperties": false
      },
      "ContractStatus": {
        "enum": [
          "Active",
          "Completed",
          "Cancelled"
        ],
        "type": "string"
      },
      "CreateAccountDto": {
        "required": [
          "code",
          "name",
          "type"
        ],
        "type": "object",
        "properties": {
          "code": {
            "minLength": 1,
            "type": "string"
          },
          "name": {
            "minLength": 1,
            "type": "string"
          },
          "type": {
            "minLength": 1,
            "type": "string"
          },
          "parentId": {
            "type": "string",
            "format": "uuid",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "CreateContractDto": {
        "type": "object",
        "properties": {
          "customerId": {
            "type": "string",
            "format": "uuid"
          },
          "currencyId": {
            "type": "string",
            "format": "uuid"
          },
          "contractDate": {
            "type": "string",
            "format": "date-time"
          },
          "totalAmount": {
            "type": "number",
            "format": "double"
          },
          "downPayment": {
            "type": "number",
            "format": "double"
          },
          "installmentCount": {
            "type": "integer",
            "format": "int32"
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ContractItemDto"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "CreateCurrencyDto": {
        "type": "object",
        "properties": {
